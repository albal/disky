# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=disky
POSTGRES_USER=disky
POSTGRES_PASSWORD=changeme

# Backend
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
SERVER_PORT=8080
APP_ENV=production

# Amazon PA API v5
AMAZON_ACCESS_KEY=your-amazon-access-key
AMAZON_SECRET_KEY=your-amazon-secret-key
AMAZON_PARTNER_TAG=prbox-21
AMAZON_MARKETPLACE=www.amazon.co.uk
AMAZON_REGION=eu-west-1

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth - Microsoft
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common

# OAuth - Apple
APPLE_CLIENT_ID=your-apple-service-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=/run/secrets/apple_private_key

# Frontend
VITE_API_URL=https://disky.tsew.com/api
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@disky.tsew.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=Disky <notifications@disky.tsew.com>

# App URL
APP_URL=https://disky.tsew.com
